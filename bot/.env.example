# Supabase — projet dédié Gan Prévoyance (bot)
SUPABASE_URL=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=
SUPABASE_PUBLISHABLE_KEY=
# Override connexion si direct IPv6 indispo (voir setup-db.mjs) :
# SUPABASE_DB_HOST=
# SUPABASE_DB_USER=
# SUPABASE_DB_PORT=5432

# LLM — Gemini 2.5 via couche OpenAI-compat
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
LLM_MAX_RETRIES=4

# Webhook — secret partagé (en-tête X-Webhook-Secret)
WEBHOOK_SECRET=
PORT=8130
HOST=0.0.0.0

# MessagingMe — API workspace Gan Prévoyance
MM_API_BASE=https://ai.messagingme.app/api
MM_API_TOKEN=
# MM_HELP_NODE_NS=
# MM_OVERFLOW_NODE_NS=

# Concurrence / pool
MAX_CONCURRENCY=15
DB_POOL_MAX=40
NO_SEND=0
